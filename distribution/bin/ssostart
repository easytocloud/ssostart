#!/usr/bin/env bash
# SSO login helper script
# Intelligently handles VS Code environments and different SSO profiles

set -euo pipefail

# Help function
show_help() {
    cat << 'EOF'
Usage: ssostart [ENV] [OPTIONS]

AWS SSO login helper that intelligently handles VS Code and terminal environments.

ARGUMENTS:
  ENV                 Optional AWS environment name from ~/.aws/aws-envs/
                      Sets AWS_CONFIG_FILE and AWS_SHARED_CREDENTIALS_FILE
                      for that environment. If ENV does not match an existing
                      environment directory it is passed through to aws sso login.

OPTIONS:
  --help              Show this help message
  Any other options   Passed directly to 'aws sso login'

AUTO SSO SESSION:
  If no $AWS_PROFILE is set and neither --profile nor --sso-session is given,
  ssostart will read the active config file and automatically pass
  --sso-session <name> when exactly one [sso-session] is found.

CONFIGURATION:
  Default options can be set in ~/.ssostartrc (one option per line)

  Example ~/.ssostartrc:
    --region eu-west-1
    --debug

ENVIRONMENT:
  - VS Code environment: Uses browser-based authentication
  - Terminal/SSH: Uses device code authentication (--no-browser --use-device-code)

AWS ENVIRONMENTS:
  Place per-environment config/credentials under ~/.aws/aws-envs/<name>/.
  Example: ~/.aws/aws-envs/hc/config and ~/.aws/aws-envs/hc/credentials

EXAMPLES:
  ssostart                              # Login with default AWS config
  ssostart hc                           # Login using ~/.aws/aws-envs/hc config
  ssostart hc --profile myprofile       # Login to myprofile within hc environment
  ssostart --profile myprofile --debug  # Login with debug output
  ssostart --region us-east-1 --profile myprofile

EOF
    exit 0
}

# Check for help flag
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    show_help
fi

# Check if first argument is an aws-env name
AWS_ENVS_DIR="$HOME/.aws/aws-envs"
if [[ $# -gt 0 && "${1:-}" != -* && -d "$AWS_ENVS_DIR/$1" ]]; then
    export AWS_CONFIG_FILE="$AWS_ENVS_DIR/$1/config"
    export AWS_SHARED_CREDENTIALS_FILE="$AWS_ENVS_DIR/$1/credentials"
    echo "Using AWS environment: $1"
    shift
fi

# Load default options from ~/.ssostartrc if it exists
EXTRA_OPTS=()
if [[ -f "$HOME/.ssostartrc" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        EXTRA_OPTS+=("$line")
    done < "$HOME/.ssostartrc"
fi

# Add all command line arguments to options
EXTRA_OPTS+=("$@")

# Auto-select SSO session if no profile or sso-session is specified
if [[ -z "${AWS_PROFILE:-}" ]]; then
    has_session_hint=false
    for opt in "${EXTRA_OPTS[@]+"${EXTRA_OPTS[@]}"}"; do
        if [[ "$opt" == "--profile" || "$opt" == --profile=* || "$opt" == "--sso-session" || "$opt" == --sso-session=* ]]; then
            has_session_hint=true
            break
        fi
    done

    if [[ "$has_session_hint" == "false" ]]; then
        config_file="${AWS_CONFIG_FILE:-$HOME/.aws/config}"
        if [[ -f "$config_file" ]]; then
            sso_sessions=()
            while IFS= read -r line; do
                sso_sessions+=("$line")
            done < <(grep '^\[sso-session ' "$config_file" | sed 's/^\[sso-session //;s/\]$//')
            if [[ ${#sso_sessions[@]} -eq 1 ]]; then
                echo "Auto-selecting SSO session: ${sso_sessions[0]}"
                EXTRA_OPTS=("--sso-session" "${sso_sessions[0]}" "${EXTRA_OPTS[@]+"${EXTRA_OPTS[@]}"}")
            fi
        fi
    fi
fi

# Determine if browser authentication is possible
# Browser auth works when:
# 1. Running in VS Code (even if VS Code is connected to a remote server)
# 2. Running in a local terminal (not SSH)
# Browser auth does NOT work when:
# - SSH session without VS Code
is_vscode=false
is_ssh=false

# Check for VS Code environment
if [[ -n "${VSCODE_IPC_HOOK_CLI:-}" ]] || [[ -n "${VSCODE_INJECTION:-}" ]] || [[ -n "${TERM_PROGRAM:-}" && "${TERM_PROGRAM}" == "vscode" ]]; then
    is_vscode=true
fi

# Check if in SSH session
# SSH sets SSH_CONNECTION and SSH_CLIENT variables
if [[ -n "${SSH_CONNECTION:-}" ]] || [[ -n "${SSH_CLIENT:-}" ]] || [[ -n "${SSH_TTY:-}" ]]; then
    is_ssh=true
fi

# Decide authentication method
if [[ "$is_vscode" == "true" ]]; then
    # VS Code environment - always use browser (VS Code handles the callback)
    echo "Detected VS Code environment - using browser authentication"
    exec aws sso login "${EXTRA_OPTS[@]+"${EXTRA_OPTS[@]}"}"
elif [[ "$is_ssh" == "false" ]]; then
    # Local terminal (not SSH) - use browser
    echo "Local terminal detected - using browser authentication"
    exec aws sso login "${EXTRA_OPTS[@]+"${EXTRA_OPTS[@]}"}"
else
    # SSH session without VS Code - use device code
    echo "SSH session detected - using device code authentication"
    exec aws sso login --no-browser --use-device-code "${EXTRA_OPTS[@]+"${EXTRA_OPTS[@]}"}"
fi
